{
  "name": "fkh",
  "displayName": "Freddy's Kubernetes Helper",
  "description": "Manage Business Central containers on Kubernetes with persisted databases, authenticated via GitHub",
  "version": "0.2.1",
  "publisher": "Freddy-DK",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Freddy-DK/Fkh"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "categories": [
    "Other",
    "Extension Packs",
    "Testing",
    "Azure"
  ],
  "keywords": [
    "Kubernetes",
    "AL",
    "AL-Go",
    "Business-Central",
    "Containers"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fkh.run",
        "title": "Fkh: Run Command"
      },
      {
        "command": "fkh.createContainer",
        "title": "Fkh: Create Container"
      },
      {
        "command": "fkh.refreshProjects",
        "title": "Fkh: Refresh Projects",
        "icon": "$(refresh)"
      },
      {
        "command": "fkh.refreshContainers",
        "title": "Fkh: Refresh Containers",
        "icon": "$(refresh)"
      },
      {
        "command": "fkh.refreshImages",
        "title": "Fkh: Refresh Images",
        "icon": "$(refresh)"
      },
      {
        "command": "fkh.refreshVMs",
        "title": "Fkh: Refresh VMs",
        "icon": "$(refresh)"
      },
      {
        "command": "fkh.startContainer",
        "title": "Start",
        "icon": "$(debug-start)"
      },
      {
        "command": "fkh.stopContainer",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "fkh.extendAutoStop",
        "title": "Extend Auto-Stop (+2h)",
        "icon": "$(watch)"
      },
      {
        "command": "fkh.setAutoStop",
        "title": "Set Auto-Stop",
        "icon": "$(clock)"
      },
      {
        "command": "fkh.removeContainer",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "fkh.createContainerForProject",
        "title": "Create Container",
        "icon": "$(vm)"
      },
      {
        "command": "fkh.getContainerLog",
        "title": "Get Container Log",
        "icon": "$(output)"
      },
      {
        "command": "fkh.getContainerEventLog",
        "title": "Get Container Event Log",
        "icon": "$(file-binary)"
      },
      {
        "command": "fkh.createImage",
        "title": "Fkh: Create Image",
        "icon": "$(add)"
      },
      {
        "command": "fkh.removeImage",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "fkh.waitForContainer",
        "title": "Wait for Ready",
        "icon": "$(sync)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fkh-explorer",
          "title": "Fkh",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "fkh-explorer": [
        {
          "id": "fkhProjects",
          "name": "AL-Go Projects",
          "icon": "$(project)",
          "visibility": "visible"
        },
        {
          "id": "fkhContainers",
          "name": "Containers",
          "icon": "$(server)",
          "visibility": "collapsed"
        },
        {
          "id": "fkhImages",
          "name": "Images",
          "icon": "$(package)",
          "visibility": "collapsed"
        },
        {
          "id": "fkhVMs",
          "name": "VMs",
          "icon": "$(server-environment)",
          "when": "fkh.isAdmin",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "fkh.refreshProjects",
          "when": "view == fkhProjects",
          "group": "navigation"
        },
        {
          "command": "fkh.refreshContainers",
          "when": "view == fkhContainers",
          "group": "navigation"
        },
        {
          "command": "fkh.createImage",
          "when": "view == fkhImages",
          "group": "navigation"
        },
        {
          "command": "fkh.refreshImages",
          "when": "view == fkhImages",
          "group": "navigation"
        },
        {
          "command": "fkh.refreshVMs",
          "when": "view == fkhVMs",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "fkh.createContainerForProject",
          "when": "view == fkhProjects && viewItem == algoProject",
          "group": "inline"
        },
        {
          "command": "fkh.createContainerForProject",
          "when": "view == fkhProjects && viewItem == algoProject",
          "group": "1_actions"
        },
        {
          "command": "fkh.startContainer",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem == container-stopped",
          "group": "inline"
        },
        {
          "command": "fkh.stopContainer",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem =~ /container-(running|starting)/",
          "group": "inline"
        },
        {
          "command": "fkh.extendAutoStop",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem =~ /container-(running|starting)/",
          "group": "inline"
        },
        {
          "command": "fkh.removeContainer",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem =~ /^container-/",
          "group": "inline"
        },
        {
          "command": "fkh.startContainer",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem == container-stopped",
          "group": "1_actions"
        },
        {
          "command": "fkh.stopContainer",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem =~ /container-(running|starting)/",
          "group": "1_actions"
        },
        {
          "command": "fkh.extendAutoStop",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem =~ /container-(running|starting)/",
          "group": "1_actions"
        },
        {
          "command": "fkh.setAutoStop",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem =~ /container-(running|starting)/",
          "group": "1_actions"
        },
        {
          "command": "fkh.removeContainer",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem =~ /^container-/",
          "group": "2_destructive"
        },
        {
          "command": "fkh.getContainerLog",
          "when": "(view == fkhContainers || view == fkhProjects || view == fkhVMs) && viewItem =~ /^container-/",
          "group": "inline"
        },
        {
          "command": "fkh.getContainerLog",
          "when": "(view == fkhContainers || view == fkhProjects || view == fkhVMs) && viewItem =~ /^container-/",
          "group": "1_actions"
        },
        {
          "command": "fkh.getContainerEventLog",
          "when": "(view == fkhContainers || view == fkhProjects || view == fkhVMs) && viewItem =~ /^container-/",
          "group": "1_actions"
        },
        {
          "command": "fkh.waitForContainer",
          "when": "(view == fkhContainers || view == fkhProjects) && viewItem =~ /container-(starting|stopped)/",
          "group": "1_actions"
        },
        {
          "command": "fkh.removeImage",
          "when": "view == fkhImages && viewItem == acrTag",
          "group": "inline"
        },
        {
          "command": "fkh.removeImage",
          "when": "view == fkhImages && viewItem == acrTag",
          "group": "2_destructive"
        }
      ]
    },
    "configuration": {
      "title": "Fkh",
      "properties": {
        "fkh.backendUrl": {
          "type": "string",
          "default": "",
          "description": "URL of the Fkh backend, e.g. https://fkh-<org_name>-backend.azurewebsites.net/api"
        },
        "fkh.timezone": {
          "type": "string",
          "default": "",
          "description": "IANA timezone (e.g. 'Europe/Copenhagen'). Set this when running in Codespaces or remote environments where the auto-detected timezone is incorrect."
        },
        "fkh.CreateContainer.updateLaunchJson": {
          "type": "string",
          "default": "project",
          "enum": ["none", "project", "repo"],
          "enumDescriptions": [
            "Do not update launch.json files after creating a container.",
            "Update launch.json files in app folders under the AL-Go project directory.",
            "Update launch.json files in app folders under the repository root."
          ],
          "description": "After creating a container, automatically add or update a launch configuration in launch.json files found in app folders."
        },
        "fkh.CreateContainer.startupObjectId": {
          "type": "number",
          "default": 22,
          "description": "The ID of the startup object in the launch configuration."
        },
        "fkh.CreateContainer.startupObjectType": {
          "type": "string",
          "default": "Page",
          "description": "The type of the startup object in the launch configuration."
        },
        "fkh.CreateContainer.startupCompany": {
          "type": "string",
          "default": "",
          "description": "The company to use at startup in the launch configuration."
        },
        "fkh.CreateContainer.schemaUpdateMode": {
          "type": "string",
          "default": "Synchronize",
          "enum": ["Synchronize", "Recreate", "ForceSync"],
          "description": "Schema update mode for the launch configuration."
        },
        "fkh.CreateContainer.launchBrowser": {
          "type": "boolean",
          "default": true,
          "description": "Whether to launch the browser when starting the debugger."
        },
        "fkh.CreateContainer.usePublicURLFromServer": {
          "type": "boolean",
          "default": true,
          "description": "Whether to use the public URL from the server."
        },
        "fkh.CreateContainer.breakOnError": {
          "type": "string",
          "default": "All",
          "enum": ["None", "All"],
          "description": "Break on error setting for the launch configuration."
        },
        "fkh.CreateContainer.breakOnRecordWrite": {
          "type": "boolean",
          "default": false,
          "description": "Whether to break on record write."
        },
        "fkh.CreateContainer.enableLongRunningSqlStatements": {
          "type": "boolean",
          "default": true,
          "description": "Whether to enable long running SQL statement tracking."
        },
        "fkh.CreateContainer.longRunningSqlStatementsThreshold": {
          "type": "number",
          "default": 500,
          "description": "Threshold in milliseconds for long running SQL statements."
        },
        "fkh.CreateContainer.numberOfSqlStatements": {
          "type": "number",
          "default": 10,
          "description": "Number of SQL statements to track."
        },
        "fkh.CreateContainer.enableSqlInformationDebugger": {
          "type": "boolean",
          "default": true,
          "description": "Whether to enable the SQL information debugger."
        },
        "fkh.CreateContainer.forceUpgrade": {
          "type": "boolean",
          "default": false,
          "description": "Whether to force upgrade when publishing."
        },
        "fkh.CreateContainer.dependencyPublishingOption": {
          "type": "string",
          "default": "Default",
          "enum": ["Default", "Ignore", "Strict"],
          "description": "Dependency publishing option for the launch configuration."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "build": "npm run build:node && npm run build:web",
    "build:node": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:web": "esbuild ./src/extension.ts --bundle --outfile=dist/web/extension.js --external:vscode --format=cjs --platform=browser",
    "watch": "npm run build:node -- --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
