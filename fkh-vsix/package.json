{
  "name": "fkh",
  "displayName": "Freddy's Kubernetes Helper",
  "description": "Provision AKS pods via authenticated Azure Function",
  "version": "0.0.1",
  "publisher": "Freddy-DK",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Freddy-DK/Fkh"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fkh.run",
        "title": "Fkh: Run Command"
      },
      {
        "command": "fkh.createPod",
        "title": "Fkh: Create Pod"
      },
      {
        "command": "fkh.refreshProjects",
        "title": "Fkh: Refresh Projects",
        "icon": "$(refresh)"
      },
      {
        "command": "fkh.refreshPods",
        "title": "Fkh: Refresh Pods",
        "icon": "$(refresh)"
      },
      {
        "command": "fkh.refreshImages",
        "title": "Fkh: Refresh Images",
        "icon": "$(refresh)"
      },
      {
        "command": "fkh.refreshNodes",
        "title": "Fkh: Refresh Nodes",
        "icon": "$(refresh)"
      },
      {
        "command": "fkh.startPod",
        "title": "Start",
        "icon": "$(debug-start)"
      },
      {
        "command": "fkh.stopPod",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "fkh.removePod",
        "title": "Remove",
        "icon": "$(trash)"
      },
      {
        "command": "fkh.createPodForProject",
        "title": "Create Pod",
        "icon": "$(vm)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fkh-explorer",
          "title": "Fkh",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "fkh-explorer": [
        {
          "id": "fkhProjects",
          "name": "AL-Go Projects",
          "icon": "$(project)",
          "visibility": "visible"
        },
        {
          "id": "fkhPods",
          "name": "Pods",
          "icon": "$(server)",
          "visibility": "collapsed"
        },
        {
          "id": "fkhImages",
          "name": "Images",
          "icon": "$(package)",
          "visibility": "collapsed"
        },
        {
          "id": "fkhNodes",
          "name": "Nodes",
          "icon": "$(server-environment)",
          "when": "fkh.isAdmin",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "fkh.refreshProjects",
          "when": "view == fkhProjects",
          "group": "navigation"
        },
        {
          "command": "fkh.refreshPods",
          "when": "view == fkhPods",
          "group": "navigation"
        },
        {
          "command": "fkh.refreshImages",
          "when": "view == fkhImages",
          "group": "navigation"
        },
        {
          "command": "fkh.refreshNodes",
          "when": "view == fkhNodes",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "fkh.createPodForProject",
          "when": "view == fkhProjects && viewItem == algoProject",
          "group": "inline"
        },
        {
          "command": "fkh.createPodForProject",
          "when": "view == fkhProjects && viewItem == algoProject",
          "group": "1_actions"
        },
        {
          "command": "fkh.startPod",
          "when": "(view == fkhPods || view == fkhProjects) && viewItem == pod-stopped",
          "group": "inline"
        },
        {
          "command": "fkh.stopPod",
          "when": "(view == fkhPods || view == fkhProjects) && viewItem =~ /pod-(running|starting)/",
          "group": "inline"
        },
        {
          "command": "fkh.removePod",
          "when": "(view == fkhPods || view == fkhProjects) && viewItem =~ /^pod-/",
          "group": "inline"
        },
        {
          "command": "fkh.startPod",
          "when": "(view == fkhPods || view == fkhProjects) && viewItem == pod-stopped",
          "group": "1_actions"
        },
        {
          "command": "fkh.stopPod",
          "when": "(view == fkhPods || view == fkhProjects) && viewItem =~ /pod-(running|starting)/",
          "group": "1_actions"
        },
        {
          "command": "fkh.removePod",
          "when": "(view == fkhPods || view == fkhProjects) && viewItem =~ /^pod-/",
          "group": "2_destructive"
        }
      ]
    },
    "configuration": {
      "title": "Fkh",
      "properties": {
        "fkh.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of the Fkh backend, e.g. https://<app>.azurewebsites.net/api"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "build": "npm run build:node && npm run build:web",
    "build:node": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:web": "esbuild ./src/extension.ts --bundle --outfile=dist/web/extension.js --external:vscode --format=cjs --platform=browser",
    "watch": "npm run build:node -- --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
